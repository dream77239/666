local LocalPlayer = Players.LocalPlayer
local ToolEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("ToolEvent")
local SellFunc = ReplicatedStorage:WaitForChild("Events"):WaitForChild("SellFunc")

local AutoPickEnabled = false
local AutoSellEnabled = false
local TeleportLocation = "Kitchen"

local Locations = {
	["Kitchen"] = Vector3.new(-130.64, 4.99, 21.00),
	["Beach"] = Vector3.new(-180.42, 4.48, -194.83),
	["Shop"] = Vector3.new(-260.38, 13.13, 84.41),
	["Sell"] = Vector3.new(-175.11, 3.98, 45.84)
}

local PickArgs = {"Activated", true}

task.spawn(function()
	while true do
		task.wait(0.1)
		if AutoPickEnabled then
			pcall(function()
				ToolEvent:FireServer(unpack(PickArgs))
			end)
		end
	end
end)

task.spawn(function()
	while true do
		task.wait(1)
		if AutoSellEnabled then
			pcall(function()
				local backpack = LocalPlayer:FindFirstChild("Backpack")
				if backpack then
					local trashData = {}
					local hasTrash = false
					
					for _, item in ipairs(backpack:GetChildren()) do
						if item:IsA("Tool") and string.sub(item.Name, 1, 6) == "Trash_" then
							local trashName = string.sub(item.Name, 7)
							if trashName and trashName ~= "" then
								trashData[trashName] = (trashData[trashName] or 0) + 1
								hasTrash = true
							end
						end
					end
					
					if hasTrash then
						local updateLootData = {
							Type = "Trash",
							UICorner = false,
							UIStroke = false,
							UIListLayout = false
						}
						for k, v in pairs(trashData) do
							updateLootData[k] = false
						end
						
						local step1Args = {"UpdateSavedLoot", updateLootData}
						SellFunc:InvokeServer(unpack(step1Args))
						task.wait(0.05)
						
						local sellData = {Type = "Trash"}
						for k, v in pairs(trashData) do
							sellData[k] = v
						end
						
						local step2Args = {"Sell", sellData}
						SellFunc:InvokeServer(unpack(step2Args))
						task.wait(0.05)
						
						local step3Args = {"GetSavedLoot"}
						SellFunc:InvokeServer(unpack(step3Args))
						task.wait(0.05)
						
						local step4Args = {
							"UpdateSavedLoot",
							{
								UIListLayout = false,
								Type = "Trash",
								UIStroke = false,
								UICorner = false
							}
						}
						SellFunc:InvokeServer(unpack(step4Args))
					end
				end
			end)
		end
	end
end)

local function Teleport()
	local character = LocalPlayer.Character
	if character then
		local rootPart = character:FindFirstChild("HumanoidRootPart")
		if rootPart then
			local targetPos = Locations[TeleportLocation]
			if targetPos then
				rootPart.CFrame = CFrame.new(targetPos)
			end
		end
	end
end

