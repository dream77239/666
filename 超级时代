	TeamCheck = not TeamCheck
	if TeamCheck then
		TeamBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
		TeamBtn.Text = "TEAM: ON"
	else
		TeamBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
		TeamBtn.Text = "TEAM: OFF"
	end
end)

TpKillBtn.MouseButton1Click:Connect(function()
	TpKillActive = not TpKillActive
	if TpKillActive then
		TpKillBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
		TpKillBtn.Text = "TP KILL: ON"
		
		TpKillConnection = RunService.Heartbeat:Connect(function()
			local MyChar = LocalPlayer.Character
			local MyRoot = MyChar and MyChar:FindFirstChild("HumanoidRootPart")
			if not MyRoot then return end
			
			if not CurrentTarget or not IsValidTarget(CurrentTarget) then
				CurrentTarget = GetRandomTarget()
			end
			
			if CurrentTarget then
				local TChar = CurrentTarget.Character
				local TRoot = TChar and TChar:FindFirstChild("HumanoidRootPart")
				local THum = TChar and TChar:FindFirstChildOfClass("Humanoid")
				
				if TRoot and THum then
					local TargetPos = TRoot.Position - (TRoot.CFrame.LookVector * 7)
					MyRoot.CFrame = CFrame.new(TargetPos, TRoot.Position)
					if IsActive then
						Attack(THum)
					end
				end
			end
		end)
	else
		TpKillBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
		TpKillBtn.Text = "TP KILL: OFF"
		if TpKillConnection then
			TpKillConnection:Disconnect()
			TpKillConnection = nil
		end
		CurrentTarget = nil
	end
end)

