local function getClosestSpill()
	local character = LocalPlayer.Character
	if not character then return nil end
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return nil end
	local spills = spillsFolder:GetChildren()
	local closestSpill = nil
	local shortestDistance = math.huge
	for _, spill in ipairs(spills) do
		local targetPos = spill:IsA("Model") and spill:GetPivot().Position or (spill:IsA("BasePart") and spill.Position)
		if targetPos then
			local distance = (rootPart.Position - targetPos).Magnitude
			if distance < shortestDistance then
				shortestDistance = distance
				closestSpill = spill
			end
		end
	end
	for _, spill in ipairs(spills) do
		if spill ~= closestSpill then spill:SetAttribute("CurrentTarget", nil) end
	end
	return closestSpill
end

local function playMoveAnimation(humanoid)
	if not currentTrack then
		local animation = Instance.new("Animation")
		animation.AnimationId = animId
		currentTrack = humanoid:LoadAnimation(animation)
		currentTrack.Looped = true
		currentTrack:Play()
	end
end

local function stopMoveAnimation()
	if currentTrack then
		currentTrack:Stop()
		currentTrack = nil
	end
end

local function checkObstacle(startPos, endPos, character)
	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.FilterDescendantsInstances = {character, spillsFolder, workspace.CurrentCamera}
	return workspace:Raycast(startPos, endPos - startPos, raycastParams)
end

local function smoothTurnTo(rootPart, lookAtTarget)
	local targetLookCFrame = CFrame.lookAt(rootPart.Position, Vector3.new(lookAtTarget.X, rootPart.Position.Y, lookAtTarget.Z))
	local startCFrame = rootPart.CFrame
	local dotProduct = rootPart.CFrame.LookVector:Dot((Vector3.new(lookAtTarget.X, rootPart.Position.Y, lookAtTarget.Z) - rootPart.Position).Unit)
	if dotProduct < 0.99 then
		local t = 0
		while t < 1 do
			t = t + task.wait() * 5
			rootPart.CFrame = startCFrame:Lerp(targetLookCFrame, math.min(t, 1))
		end
	end
end

local function doTween(rootPart, destination)
	local distance = (destination - rootPart.Position).Magnitude
	if distance < 0.5 then return true end
	local humanoid = rootPart.Parent:FindFirstChild("Humanoid")
	local speed = (humanoid and humanoid.WalkSpeed > 0) and humanoid.WalkSpeed or 16
	local duration = distance / speed
	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.FilterDescendantsInstances = {rootPart.Parent, spillsFolder, workspace.CurrentCamera}
	smoothTurnTo(rootPart, destination)
	local currentRotation = rootPart.CFrame.Rotation
	local tween = TweenService:Create(rootPart, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = CFrame.new(destination) * currentRotation})
	local completed = false
	local connection
	connection = tween.Completed:Connect(function() completed = true connection:Disconnect() end)
	if humanoid then playMoveAnimation(humanoid) end
	tween:Play()
	while not completed do
		if not scriptRunning or not rootPart or not rootPart.Parent then
			tween:Cancel()
			if connection then connection:Disconnect() end
			stopMoveAnimation()
			return false
		end
		if humanoid then humanoid:ChangeState(Enum.HumanoidStateType.Running) end
		local currentPos = rootPart.Position
		local groundRay = workspace:Raycast(currentPos + Vector3.new(0, 2, 0), Vector3.new(0, -15, 0), raycastParams)
		local currentY = currentPos.Y
		if groundRay then currentY = groundRay.Position.Y + 3 end
		local lookAtTarget = Vector3.new(destination.X, currentY, destination.Z)
		if (lookAtTarget - currentPos).Magnitude > 0.2 then
			rootPart.CFrame = CFrame.lookAt(Vector3.new(currentPos.X, currentY, currentPos.Z), lookAtTarget)
		else
			rootPart.CFrame = CFrame.new(currentPos.X, currentY, currentPos.Z) * rootPart.CFrame.Rotation
		end
		task.wait()
	end
	return true
end

local function tweenMoveWithAvoidance(character, targetInstance)
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return false end
	local targetPos = targetInstance:IsA("Model") and targetInstance:GetPivot().Position or targetInstance.Position
	local destination = targetPos + Vector3.new(0, 3, 0)
	local maxAttempts = 3
	local attempts = 0
	while attempts < maxAttempts do
		local currentPos = rootPart.Position
		local hit = checkObstacle(currentPos, destination, character)
		if not hit then break end
		attempts = attempts + 1
		local direction = (destination - currentPos).Unit
		local leftDir = CFrame.Angles(0, math.rad(55), 0) * direction
		local rightDir = CFrame.Angles(0, math.rad(-55), 0) * direction
		local bypassDistance = 7
		local leftPoint = Vector3.new(currentPos.X + (leftDir.X * bypassDistance), currentPos.Y, currentPos.Z + (leftDir.Z * bypassDistance))
		local rightPoint = Vector3.new(currentPos.X + (rightDir.X * bypassDistance), currentPos.Y, currentPos.Z + (rightDir.Z * bypassDistance))
		local leftHit = checkObstacle(currentPos, leftPoint, character)
		local rightHit = checkObstacle(currentPos, rightPoint, character)
		local bypassPoint = nil
		if not leftHit then bypassPoint = leftPoint elseif not rightHit then bypassPoint = rightPoint else bypassPoint = currentPos + Vector3.new(0, 5, 0) end
		if bypassPoint then
			local success = doTween(rootPart, bypassPoint)
			if not success then return false end
		end
	end
	local finalSuccess = doTween(rootPart, destination)
	stopMoveAnimation()
	return finalSuccess
end

