local function getMuzzlePosition()
	local camera = workspace.CurrentCamera
	if camera then
		local viewmodel = camera:FindFirstChild("Viewmodel")
		local equipped = viewmodel and viewmodel:FindFirstChild("Equipped")
		local weaponModel = equipped and equipped:FindFirstChild("WeaponModel")
		if weaponModel then
			local attachNodes = weaponModel:FindFirstChild("AttachmentNodes")
			if attachNodes then
				local muzzle = attachNodes:FindFirstChild("muzzle")
				if muzzle and muzzle:IsA("BasePart") then
					return muzzle.Position
				end
			end
			local equippedAttachments = weaponModel:FindFirstChild("EquippedAttachments")
			if equippedAttachments then
				for _, child in ipairs(equippedAttachments:GetChildren()) do
					if child.Name:match("barrel") or child.Name:match("muzzle") or child.Name:match("Muzzle") then
						return child.Position
					end
				end
			end
			local fallback = weaponModel:FindFirstChild("muzzle") or weaponModel:FindFirstChild("Muzzle") or weaponModel:FindFirstChild("Tip") or weaponModel:FindFirstChild("Handle") or weaponModel:FindFirstChildOfClass("Part")
			if fallback and fallback:IsA("BasePart") then
				return fallback.Position
			end
		end
	end
	local character = LocalPlayer.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	return root and root.Position
end

local function checkIsGun()
	local camera = workspace.CurrentCamera
	if camera then
		local viewmodel = camera:FindFirstChild("Viewmodel")
		local equipped = viewmodel and viewmodel:FindFirstChild("Equipped")
		local weaponModel = equipped and equipped:FindFirstChild("WeaponModel")
		if weaponModel then
			local animNodes = weaponModel:FindFirstChild("AnimationNodes")
			local attachNodes = weaponModel:FindFirstChild("AttachmentNodes")
			
			local hasAnimChildren = animNodes and #animNodes:GetChildren() > 0
			local hasAttachChildren = attachNodes and #attachNodes:GetChildren() > 0
			
			if hasAnimChildren or hasAttachChildren then
				return true
			end
		end
	end
	return false
end

local function damagePrimary(target, head)
	local character = LocalPlayer.Character
	if not character then return end
	
	local currentTool = character:FindFirstChildOfClass("Tool")
	if currentTool and currentTool.Name == "melee" then
		return
	end
	
	if not checkIsGun() then
		return
	end
	
	local primary = character:FindFirstChild("primary")
	if not primary and currentTool and currentTool.Name ~= "melee" then
		primary = currentTool
	end
	
	if primary then
		local events = primary:FindFirstChild("ServerEvents")
		local registerHit = events and events:FindFirstChild("RegisterHit")
		if registerHit then
			local args = {
				{
					{
						amount = 1,
						target = target,
						is_friendly = false,
						part = head,
						cast_results = nil
					}
				},
				{}
			}
			registerHit:FireServer(unpack(args))
			
			local muzzlePos = getMuzzlePosition()
			if muzzlePos and head then
				drawTracer(muzzlePos, head.Position)
				playHitSound(head)
			end
		end
	end
end

local function applyEsp(target)
	if espState then
		if not target:FindFirstChildOfClass("Highlight") then
			local highlight = Instance.new("Highlight")
			highlight.FillTransparency = 1
			highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
			highlight.OutlineTransparency = 0
			highlight.Adornee = target
			highlight.Parent = target
		end
	else
		local highlight = target:FindFirstChildOfClass("Highlight")
		if highlight then
			highlight:Destroy()
		end
	end
end

local function scan(folder)
	if folder then
		for _, v in ipairs(folder:GetChildren()) do
			applyEsp(v)
			if auraState then
				local head = v:FindFirstChild("Head")
				if head then
					damagePrimary(v, head)
				end
			end
		end
	end
end

local function applyForceField(instance)
	if instance:IsA("BasePart") then
		if not originalMaterials[instance] then
			originalMaterials[instance] = instance.Material
			originalColors[instance] = instance.Color
			originalTransparencies[instance] = instance.Transparency
		end
		instance.Material = Enum.Material.ForceField
		instance.Color = handsColor
		if instance.Transparency > 0.3 then
			instance.Transparency = 0.3
		end
	end
	for _, child in ipairs(instance:GetChildren()) do
		applyForceField(child)
	end
end

local function restoreOriginal(instance)
	if instance:IsA("BasePart") then
		if originalMaterials[instance] then
			instance.Material = originalMaterials[instance]
			instance.Color = originalColors[instance]
			instance.Transparency = originalTransparencies[instance]
			originalMaterials[instance] = nil
			originalColors[instance] = nil
			originalTransparencies[instance] = nil
		end
	end
	for _, child in ipairs(instance:GetChildren()) do
		restoreOriginal(child)
	end
end

