local function IsValidCharacter(char)
    if not char then return false end
    local human = char:FindFirstChildOfClass("Humanoid")
    local head = char:FindFirstChild("Head")
    if not human or not head or human.Health <= 0 then return false end
    if char:FindFirstChildOfClass("ForceField") then return false end
    if char.Name == "Dead" then return false end
    return true
end

local function IsValidPlayer(player)
    if not player or player == LocalPlayer or not player.Character then return false end
    if player.Team and player.Team.Name == "Dead" then return false end
    return IsValidCharacter(player.Character)
end

local function IsVisible(targetHead)
    if not WallCheck then return true end
    local castPoints = {Camera.CFrame.Position, targetHead.Position}
    local ignoreList = {LocalPlayer.Character, targetHead.Parent}
    local parts = Camera:GetPartsObscuringTarget(castPoints, ignoreList)
    return #parts == 0
end

local function GetClosestTarget(screenCenter)
    local closestTarget = nil
    local maxDistance = FOVRadius

    if AimbotTargetMode == "Players" then
        for _, player in pairs(Players:GetPlayers()) do
            if IsValidPlayer(player) then
                if not TeamCheck or (TeamCheck and player.Team ~= LocalPlayer.Team) then
                    local head = player.Character.Head
                    local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                    if onScreen and IsVisible(head) then
                        local distance = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                        if distance < maxDistance then
                            maxDistance = distance
                            closestTarget = head
                        end
                    end
                end
            end
        end
    elseif AimbotTargetMode == "NPCs" then
        for _, desc in pairs(Workspace:GetDescendants()) do
            if desc:IsA("Model") and desc:FindFirstChildOfClass("Humanoid") and not Players:GetPlayerFromCharacter(desc) then
                if IsValidCharacter(desc) then
                    local head = desc:FindFirstChild("Head")
                    if head then
                        local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                        if onScreen and IsVisible(head) then
                            local distance = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                            if distance < maxDistance then
                                maxDistance = distance
                                closestTarget = head
                            end
                        end
                    end
                end
            end
        end
    end
    return closestTarget
end

RunService.RenderStepped:Connect(function()
    local screenSize = Camera.ViewportSize
    local screenCenter = Vector2.new(screenSize.X / 2, screenSize.Y / 2)

    if AimbotEnabled then
        local target = GetClosestTarget(screenCenter)
        if target then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
        end
    end

    for _, player in pairs(Players:GetPlayers()) do
        if IsValidPlayer(player) and ESPEnabled then
            local char = player.Character
            local isAlly = (player.Team == LocalPlayer.Team)
            local boxHighlight = Storage.ESP[player]
            
            if not boxHighlight or not boxHighlight.Box or not boxHighlight.Box.Parent then
                if boxHighlight and boxHighlight.Box then boxHighlight.Box:Destroy() end
                local box = Instance.new("Highlight")
                box.FillTransparency = 1
                box.OutlineTransparency = 0
                box.Adornee = char
                box.Parent = CoreGui
                Storage.ESP[player] = {Box = box}
                boxHighlight = Storage.ESP[player]
            end

            boxHighlight.Box.OutlineColor = isAlly and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
            boxHighlight.Box.Adornee = char
        else
            if Storage.ESP[player] and Storage.ESP[player].Box then
                Storage.ESP[player].Box:Destroy()
                Storage.ESP[player] = nil
            end
        end
    end

    for player, item in pairs(Storage.ESP) do
        if not Players:FindFirstChild(player.Name) then
            if item.Box then item.Box:Destroy() end
            Storage.ESP[player] = nil
        end
    end

    if NPCCheck then
        local currentNPCs = {}
        for _, desc in pairs(Workspace:GetDescendants()) do
            if desc:IsA("Model") and desc:FindFirstChildOfClass("Humanoid") and not Players:GetPlayerFromCharacter(desc) then
                if IsValidCharacter(desc) then
                    currentNPCs[desc] = true
                    local boxHighlight = Storage.NPC_ESP[desc]
                    if not boxHighlight or not boxHighlight.Box or not boxHighlight.Box.Parent then
                        if boxHighlight and boxHighlight.Box then boxHighlight.Box:Destroy() end
                        local box = Instance.new("Highlight")
                        box.FillTransparency = 1
                        box.OutlineTransparency = 0
                        box.OutlineColor = Color3.fromRGB(128, 0, 128)
                        box.Adornee = desc
                        box.Parent = CoreGui
                        Storage.NPC_ESP[desc] = {Box = box}
                        boxHighlight = Storage.NPC_ESP[desc]
                    end
                    boxHighlight.Box.Adornee = desc
                end
            end
        end

        for npc, item in pairs(Storage.NPC_ESP) do
            if not currentNPCs[npc] then
                if item.Box then item.Box:Destroy() end
                Storage.NPC_ESP[npc] = nil
            end
        end
    else
        ClearAllNPCESP()
    end
end)

