local Workspace = game:GetService("Workspace")

local entitiesFolder = Workspace:FindFirstChild("Entities")
local debrisFolder = Workspace:FindFirstChild("Debris")
local espEnabled = false
local connections = {}

local function removeESP(entity)
    if entity:FindFirstChild("ESPHighlight") then
        entity.ESPHighlight:Destroy()
    end
end

local function clearAllESP()
    for _, conn in pairs(connections) do
        conn:Disconnect()
    end
    table.clear(connections)

    if entitiesFolder then
        for _, entity in ipairs(entitiesFolder:GetChildren()) do
            removeESP(entity)
        end
    end
    
    if debrisFolder then
        for _, entity in ipairs(debrisFolder:GetChildren()) do
            if entity.Name == "PunchlineBox" then
                removeESP(entity)
            end
        end
    end
end

local function applyESP(entity)
    if not espEnabled then return end
    if not entity:IsA("Model") then return end

    local highlight = entity:FindFirstChild("ESPHighlight")
    if not highlight then
        highlight = Instance.new("Highlight")
        highlight.Name = "ESPHighlight"
        highlight.FillColor = Color3.fromRGB(255, 0, 0)
        highlight.FillTransparency = 1 
        highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
        highlight.OutlineTransparency = 0
        highlight.Adornee = entity
        highlight.Parent = entity
    end
end

local function watchEntity(entity)
    if not entity:IsA("Model") then return end
    
    applyESP(entity)

    local childConn = entity.ChildAdded:Connect(function()
        task.wait(0.1)
        applyESP(entity)
    end)
    table.insert(connections, childConn)
end

local function checkAndWatchDebris(child)
    if child.Name == "PunchlineBox" then
        watchEntity(child)
    end
end

local function startESP()
    if entitiesFolder then
        for _, entity in ipairs(entitiesFolder:GetChildren()) do
            watchEntity(entity)
        end

        local addedConn = entitiesFolder.ChildAdded:Connect(function(entity)
            task.wait(0.1)
            watchEntity(entity)
        end)
        table.insert(connections, addedConn)
    end

    if debrisFolder then
        for _, child in ipairs(debrisFolder:GetChildren()) do
            checkAndWatchDebris(child)
        end

        local debrisConn = debrisFolder.ChildAdded:Connect(function(child)
            task.wait(0.1)
            checkAndWatchDebris(child)
        end)
        table.insert(connections, debrisConn)
        
        local debrisRemovedConn = debrisFolder.ChildRemoved:Connect(function(child)
            if child.Name == "PunchlineBox" then
                removeESP(child)
            end
        end)
        table.insert(connections, debrisRemovedConn)
    end
end

