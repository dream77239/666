            if type(stats) == "table" and rawget(stats, "firerate") then
                if noRecoil then
                    stats.vertical_recoil = 0
                    stats.horizontal_recoil = 0
                else
                    stats.vertical_recoil = 1
                    stats.horizontal_recoil = 0.85
                end
                
                if fastFire then
                    stats.firerate = 5000
                else
                    stats.firerate = 800
                end
            end
        end
    end
end

