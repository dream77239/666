local function isPlayingAnim()
    local char = Players.LocalPlayer.Character
    if not char then return false end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    local animator = humanoid:FindFirstChildOfClass("Animator")
    if not animator then return false end
    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
        if track.Animation and track.Animation.AnimationId:find(TARGET_ANIM) then
            return true
        end
    end
    return false
end

local function fireAll()
    while current_id <= 500 do
        if not running then break end
        if isPlayingAnim() then
            task.wait(3)
            if not running then break end
            if isPlayingAnim() then
                local b = buffer.create(3)
                buffer.writeu8(b, 0, 0)
                buffer.writeu8(b, 1, current_id)
                buffer.writeu8(b, 2, 1)
                remote:FireServer(b)
                current_id = current_id + 1
            end
        end
        task.wait(interval)
    end
end

local function setRunning(val)
    running = val
    if running then
        thread = task.spawn(function()
            fireAll()
        end)
    else
        if thread then task.cancel(thread) thread = nil end
    end
end

