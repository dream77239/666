                    local targetPosition = entityPos + (direction * (avoidDistance + 5))
                    rootPart.CFrame = CFrame.new(Vector3.new(targetPosition.X, currentPos.Y, targetPosition.Z), Vector3.new(entityPos.X, currentPos.Y, entityPos.Z))
