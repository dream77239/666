local connections = {}

local function createHighlight(target, parent)
    if activeESP[target] then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.FillColor = Color3.fromRGB(138, 43, 226)
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(148, 0, 211)
    highlight.OutlineTransparency = 0
    highlight.Adornee = target
    highlight.Parent = parent
    
    activeESP[target] = highlight
end

local function removeHighlight(target)
    if activeESP[target] then
        activeESP[target]:Destroy()
        activeESP[target] = nil
    end
end

local function checkWirePanel(child)
    if child.Name == "WirePanel" then
        if child:FindFirstChild("WirePanelHighlight", true) then
            if espEnabled then
                createHighlight(child, child)
            end
        end
    end
end

local function checkDebrisEntity(child)
    if child.Name == "PunchlineBox" then return end
    if espEnabled and child:IsA("Instance") then
        createHighlight(child, child)
    end
end

local function updateESP(state)
    espEnabled = state
    
    if not espEnabled then
        for _, conn in pairs(connections) do
            conn:Disconnect()
        end
        connections = {}
        
        for target, highlight in pairs(activeESP) do
            highlight:Destroy()
        end
        activeESP = {}
    else
        if mapPath then
            for _, child in pairs(mapPath:GetChildren()) do
                checkWirePanel(child)
            end
            table.insert(connections, mapPath.ChildAdded:Connect(checkWirePanel))
            table.insert(connections, mapPath.ChildRemoved:Connect(removeHighlight))
        end
        
        if debrisPath then
            for _, child in pairs(debrisPath:GetChildren()) do
                checkDebrisEntity(child)
            end
            table.insert(connections, debrisPath.ChildAdded:Connect(checkDebrisEntity))
            table.insert(connections, debrisPath.ChildRemoved:Connect(removeHighlight))
        end
        
        table.insert(connections, RunService.Heartbeat:Connect(function()
            if mapPath then
                for _, child in pairs(mapPath:GetChildren()) do
                    if child.Name == "WirePanel" then
                        local hasHighlight = child:FindFirstChild("WirePanelHighlight", true)
                        if hasHighlight and not activeESP[child] then
                            createHighlight(child, child)
                        elseif not hasHighlight and activeESP[child] then
                            removeHighlight(child)
                        end
                    end
                end
            end
        end))
    end
end

