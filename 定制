                local hl = Instance.new("Highlight")
                hl.Name = "_KanlHL"
                hl.FillTransparency = 1
                hl.OutlineTransparency = 0
                hl.OutlineColor = outlineColor
                hl.FillColor = outlineColor
                hl.Adornee = parent
                hl.Parent = parent
            end

            local function applyPlayerEsp(plr)
                if plr == game:GetService("Players").LocalPlayer then return end
                local function onChar(char)
                    if playerEspOn then applyHighlight(char, Color3.fromRGB(0, 255, 0)) end
                end
                if plr.Character then onChar(plr.Character) end
                plr.CharacterAdded:Connect(onChar)
            end

            for _, plr in ipairs(game:GetService("Players"):GetPlayers()) do 
                applyPlayerEsp(plr) 
            end

            game:GetService("Players").PlayerAdded:Connect(function(plr)
                if playerEspOn then applyPlayerEsp(plr) end
            end)
        else
            for _, plr in ipairs(game:GetService("Players"):GetPlayers()) do
                if plr ~= game:GetService("Players").LocalPlayer and plr.Character then
                    local hl = plr.Character:FindFirstChild("_KanlHL")
                    if hl then hl:Destroy() end
                end
            end
        end
    end
})
