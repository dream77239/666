    textLabel.BackgroundTransparency = 1
    textLabel.TextColor3 = color
    textLabel.TextSize = 14
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextStrokeTransparency = 0
    textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.Visible = (folderType == "survivor" and survivorDistanceEnabled) or (folderType == "killer" and killerDistanceEnabled) or (folderType == "generator" and genDistanceEnabled)
    textLabel.Parent = billboard

    espObjects[instance] = {
        Highlight = highlight,
        Billboard = billboard,
        TextLabel = textLabel,
        RootPart = hrp,
        Type = folderType
    }
end

local function removeESP(instance)
    local cache = espObjects[instance]
