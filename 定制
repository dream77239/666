local function createESP(instance, color, folderType)
    if not instance then return end
    if folderType ~= "generator" and not instance:IsA("Model") then return end
    if instance.Name == localPlayer.Name then return end

    local hrp = instance:IsA("Model") and instance:FindFirstChild("HumanoidRootPart") or instance:IsA("BasePart") and instance or instance:FindFirstChildWhichIsA("BasePart")
    if not hrp then return end

    local cache = espObjects[instance]
    if cache then
        if cache.Highlight and cache.Highlight.Parent == instance then
            cache.Highlight.OutlineColor = color
            cache.Highlight.Enabled = true
        else
            if cache.Highlight then cache.Highlight:Destroy() end
            local highlight = Instance.new("Highlight")
            highlight.Name = "ESPHighlight"
            highlight.FillTransparency = 1
            highlight.OutlineColor = color
            highlight.OutlineTransparency = 0
            highlight.Adornee = instance
            highlight.Parent = instance
            cache.Highlight = highlight
        end
        
        if cache.Billboard and cache.Billboard.Parent == hrp then
            cache.TextLabel.TextColor3 = color
            cache.TextLabel.Visible = (folderType == "survivor" and survivorDistanceEnabled) or (folderType == "killer" and killerDistanceEnabled) or (folderType == "generator" and genDistanceEnabled)
        else
            if cache.Billboard then cache.Billboard:Destroy() end
            local billboard = Instance.new("BillboardGui")
            billboard.Name = "ESPDistance"
            billboard.Size = UDim2.new(0, 100, 0, 30)
            billboard.AlwaysOnTop = true
            billboard.MaxDistance = math.huge
            billboard.Adornee = hrp
            billboard.Parent = hrp

            local textLabel = Instance.new("TextLabel")
            textLabel.Size = UDim2.new(1, 0, 1, 0)
            textLabel.BackgroundTransparency = 1
            textLabel.TextColor3 = color
            textLabel.TextSize = 14
            textLabel.Font = Enum.Font.GothamBold
            textLabel.TextStrokeTransparency = 0
            textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
            textLabel.Visible = (folderType == "survivor" and survivorDistanceEnabled) or (folderType == "killer" and killerDistanceEnabled) or (folderType == "generator" and genDistanceEnabled)
            textLabel.Parent = billboard

            cache.Billboard = billboard
            cache.TextLabel = textLabel
            cache.RootPart = hrp
        end
        cache.Type = folderType
        return
    end

    local highlight = Instance.new("Highlight")
    highlight.Name = "ESPHighlight"
    highlight.FillTransparency = 1
    highlight.OutlineColor = color
    highlight.OutlineTransparency = 0
    highlight.Adornee = instance
    highlight.Parent = instance

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESPDistance"
    billboard.Size = UDim2.new(0, 100, 0, 30)
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = math.huge
    billboard.Adornee = hrp
    billboard.Parent = hrp

    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.TextColor3 = color
    textLabel.TextSize = 14
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextStrokeTransparency = 0
    textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.Visible = (folderType == "survivor" and survivorDistanceEnabled) or (folderType == "killer" and killerDistanceEnabled) or (folderType == "generator" and genDistanceEnabled)
    textLabel.Parent = billboard

    espObjects[instance] = {
        Highlight = highlight,
        Billboard = billboard,
        TextLabel = textLabel,
        RootPart = hrp,
        Type = folderType
    }
end

local function removeESP(instance)
    local cache = espObjects[instance]
    if cache then
        if cache.Highlight then cache.Highlight:Destroy() end
        if cache.Billboard then cache.Billboard:Destroy() end
        espObjects[instance] = nil
    end
end

local function fastScan()
    if survivorEspEnabled then
        local survivors = workspace:FindFirstChild("survivors")
        if survivors then
            for _, child in ipairs(survivors:GetChildren()) do
                if child:IsA("Model") and child.Name ~= localPlayer.Name then
                    if not espObjects[child] or not child:FindFirstChild("ESPHighlight") then
                        createESP(child, Color3.fromRGB(0, 255, 0), "survivor")
                    end
                end
            end
        end
    end

    if killerEspEnabled then
        local killers = workspace:FindFirstChild("killers")
        if killers then
            for _, child in ipairs(killers:GetChildren()) do
                if child:IsA("Model") then
                    if not espObjects[child] or not child:FindFirstChild("ESPHighlight") then
                        createESP(child, Color3.fromRGB(255, 0, 0), "killer")
                    end
                end
            end
        end
    end

    if genEspEnabled then
        local mapFolder = workspace:FindFirstChild("map")
        local mapInner = mapFolder and mapFolder:FindFirstChild("map")
        if mapInner then
            for _, child in ipairs(mapInner:GetChildren()) do
                if child.Name == "template_generator" then
                    if not espObjects[child] or not child:FindFirstChild("ESPHighlight") then
                        createESP(child, Color3.fromRGB(160, 32, 240), "generator")
                    end
                end
            end
        end
    end
end

local function updateConnections()
    for _, conn in ipairs(connections) do
        conn:Disconnect()
    end
    table.clear(connections)

    if not survivorEspEnabled and not killerEspEnabled and not genEspEnabled then return end

    local survivors = workspace:FindFirstChild("survivors")
    local killers = workspace:FindFirstChild("killers")
    local mapFolder = workspace:FindFirstChild("map")
    local mapInner = mapFolder and mapFolder:FindFirstChild("map")

    if survivorEspEnabled and survivors then
        table.insert(connections, survivors.ChildAdded:Connect(function(child)
            if survivorEspEnabled then createESP(child, Color3.fromRGB(0, 255, 0), "survivor") end
        end))
        table.insert(connections, survivors.ChildRemoved:Connect(removeESP))
    end

    if killerEspEnabled and killers then
        table.insert(connections, killers.ChildAdded:Connect(function(child)
            if killerEspEnabled then createESP(child, Color3.fromRGB(255, 0, 0), "killer") end
        end))
        table.insert(connections, killers.ChildRemoved:Connect(removeESP))
    end

    if genEspEnabled and mapInner then
        table.insert(connections, mapInner.ChildAdded:Connect(function(child)
            if genEspEnabled and child.Name == "template_generator" then createESP(child, Color3.fromRGB(160, 32, 240), "generator") end
        end))
        table.insert(connections, mapInner.ChildRemoved:Connect(removeESP))
    end

    table.insert(connections, RunService.RenderStepped:Connect(function()
        local now = os.clock()
        if now - lastUpdate >= UPDATE_INTERVAL then
            lastUpdate = now
            fastScan()
        end
        
        local localChar = localPlayer.Character
        local localHRP = localChar and localChar:FindFirstChild("HumanoidRootPart")
        
        for instance, data in pairs(espObjects) do
            if not instance.Parent then
                removeESP(instance)
            elseif data.TextLabel.Visible and localHRP and data.RootPart and data.RootPart.Parent then
                local dist = (localHRP.Position - data.RootPart.Position).Magnitude
                data.TextLabel.Text = math.floor(dist) .. "m"
            elseif data.TextLabel.Visible and (not localHRP or not data.RootPart or not data.RootPart.Parent) then
                data.TextLabel.Text = ""
            end
        end
    end))
end

local function clearObjectsByType(folderType)
    for instance, data in pairs(espObjects) do
        if data.Type == folderType then
            if data.Highlight then data.Highlight:Destroy() end
            if data.Billboard then data.Billboard:Destroy() end
            espObjects[instance] = nil
        end
    end
end

