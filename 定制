                end
                
                for _, target in ipairs(targets) do
                    if not states[key] then break end
                    local prompt = nil
                    for _, desc in ipairs(target:GetDescendants()) do
                        if desc:IsA("ProximityPrompt") then
                            prompt = desc
                            break
                        end
                    end
                    if prompt and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                        local cf = nil
                        if target:IsA("BasePart") then
                            cf = target.CFrame
                        elseif target:IsA("Model") then
