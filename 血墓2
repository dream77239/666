local function isTargetRemote(obj)
	return typeof(obj) == "Instance" and obj.ClassName == "RemoteEvent" and obj.Name == "MoveArms"
end

local targetNC
targetNC = hookmetamethod(game, "__namecall", function(self, ...)
	local method = getnamecallmethod()
	if Config.Enabled and (method == "FireServer" or method == "fireServer") and isTargetRemote(self) then
		return targetNC(self, Config.RightArmCFrame, Config.LeftArmCFrame)
	end
	return targetNC(self, ...)
end)

local targetIdx
targetIdx = hookmetamethod(game, "__index", function(self, key)
	if Config.Enabled and (key == "FireServer" or key == "fireServer") and isTargetRemote(self) then
		return function(rem, ...)
			return targetNC(rem, Config.RightArmCFrame, Config.LeftArmCFrame)
		end
	end
	return targetIdx(self, key)
end)

if getgenv and typeof(getgenv) == "function" then
	local hookFunction = getgenv().hookfunction or getgenv().replaceclosure
	if hookFunction then
		local success, remoteMeta = pcall(function()
			return debug.getrawmetatable(game:GetService("ReplicatedStorage")) or debug.getrawmetatable(game)
		end)
		
		if success and remoteMeta and remoteMeta.__index then
			local orgFireServer = Instance.new("RemoteEvent").FireServer
			hookFunction(orgFireServer, newcclosure(function(self, ...)
				if Config.Enabled and isTargetRemote(self) then
					return targetNC(self, Config.RightArmCFrame, Config.LeftArmCFrame)
				end
				return orgFireServer(self, ...)
			end))
		end
	end
end

