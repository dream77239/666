FOV_Circle.Filled = false
FOV_Circle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

Camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
    FOV_Circle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
end)

local function updateTarget()
    if not scriptActive then 
        cachedTarget = nil 
        return 
    end
    
    local targetFolder = Workspace:FindFirstChild("Enemies")
    if not targetFolder then
        cachedTarget = nil
        return
    end

    local targetObj = targetFolder:FindFirstChild("Bloodgraven")
    if targetObj then
        local head = targetObj:FindFirstChild("HeadHitbox") or targetObj:FindFirstChild("Head")
        local hum = targetObj:FindFirstChildOfClass("Humanoid")
        if head and hum and hum.Health > 0 then
            local camCF = Camera.CFrame
            local dir = (head.Position - camCF.Position)
            local angle = math.deg(math.acos(camCF.LookVector:Dot(dir.Unit)))
            if angle <= (FOV_Circle.Radius / 6.6) then
                cachedTarget = head
                return
            end
        end
    end
    cachedTarget = nil
end

RunService.RenderStepped:Connect(function()
    if tick() - lastUpdate > updateDelay then
        lastUpdate = tick()
        updateTarget()
    end
end)

local isHooking = false
local old
old = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if scriptActive and not checkcaller() and not isHooking and self == Workspace then
        if cachedTarget and (method == "Raycast" or method == "FindPartOnRay") then
            isHooking = true
            local args = {...}
            local origin
            if method == "Raycast" then
                origin = args[1]
            else
                local ray = args[1]
                if typeof(ray) == "Ray" then origin = ray.Origin end
            end
            if origin then
                local hitPos = cachedTarget.Position
                isHooking = false
                return {
                    Instance = cachedTarget,
                    Position = hitPos,
                    Normal = Vector3.new(0, 1, 0),
                    Material = Enum.Material.Plastic,
                    Distance = (hitPos - origin).Magnitude
                }
            end
            isHooking = false
        end
    end
    return old(self, ...)
end)

TabCombat:Toggle({
    Title = "子追",
    Value = false,
    Callback = function(state)
        scriptActive = state
        FOV_Circle.Visible = state
    end
})

TabCombat:Slider({
    Title = "子追圈大小",
    Value = {
        Min = 10,
        Max = 500,
        Default = 100,
    },
    Callback = function(value)
        FOV_Circle.Radius = value
    end
})
