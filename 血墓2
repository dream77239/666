local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local isAttacking = false
local lastAttackTime = 0
local attackInterval = 0.01

local function getValidTargets()
	local targets = {}
	local container = workspace:FindFirstChild("Enemie") or workspace:FindFirstChild("Enemies")
	if not container then return targets end
	
	for _, child in ipairs(container:GetChildren()) do
		local humanoid = child:FindFirstChildOfClass("Humanoid")
		local isAlive = true
		
		if humanoid and (humanoid.Health <= 0 or child:GetAttribute("Dead") == true or child:GetAttribute("IsDead") == true) then
			isAlive = false
		end
		
		if isAlive then
			local head = child:FindFirstChild("HeadHitbox") or child:FindFirstChild("Head")
			if head then
				table.insert(targets, head)
			end
		end
	end
	return targets
end

local loopConnection
local function startLoop()
	if loopConnection then loopConnection:Disconnect() end
	loopConnection = RunService.Heartbeat:Connect(function()
		if not isAttacking then return end
		
		local now = tick()
		if now - lastAttackTime < attackInterval then return end
		
		local character = localPlayer.Character
		if not character then return end
		
		local weapon = character:FindFirstChild("M4A1")
		if not weapon then return end
		
		local assets = weapon:FindFirstChild("Assets")
		local remotes = assets and assets:FindFirstChild("Remotes")
		if not remotes then return end
		
		local fireRemote = remotes:FindFirstChild("Fire")
		local reloadRemote = remotes:FindFirstChild("Reload")
		
		local handle = weapon:FindFirstChild("Handle")
		local muzzlePoint = handle and handle:FindFirstChild("GunMuzzlePoint")
		
		if not fireRemote or not reloadRemote or not muzzlePoint then return end
		
		local validTargets = getValidTargets()
		if #validTargets == 0 then return end
		
		lastAttackTime = now
		
		local originPos = muzzlePoint.Position
		if muzzlePoint:IsA("Attachment") then
			originPos = muzzlePoint.WorldPosition
		end
		
		for _, targetHead in ipairs(validTargets) do
			local targetPos = targetHead.Position
			local direction = (targetPos - originPos).Unit
			if direction.Magnitude == 0 or direction.X ~= direction.X then
				direction = Vector3.new(0, 1, 0)
			end
			
			local fireArgs1 = {
				Vector3.new(targetPos.X, targetPos.Y, targetPos.Z),
				Vector3.new(direction.X, direction.Y, direction.Z),
				muzzlePoint
			}
			
			local fireArgs2 = {
				Vector3.new(originPos.X, originPos.Y, originPos.Z),
				Vector3.new(targetPos.X, targetPos.Y, targetPos.Z),
				muzzlePoint
			}
			
			fireRemote:FireServer(unpack(fireArgs1))
			fireRemote:FireServer(unpack(fireArgs2))
		end
		
		local reloadArgs = { false }
		reloadRemote:FireServer(unpack(reloadArgs))
	end)
end

