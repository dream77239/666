		local v27 = math.floor(v26) % 65536
		v21 = (v25 * 403 + (v25 * 256 + v27 * 403) % 65536 * 65536) % 4294967296
	end
	local v28 = bit32.rshift(v21, 16)
	local v29 = bit32.bxor(v21, v28)
	local v30 = v29 % 65536
	local v31 = v29 / 65536
	local v32 = math.floor(v31) % 65536
	local v33 = (v30 * 51819 + (v30 * 34283 + v32 * 51819) % 65536 * 65536) % 4294967296
	local v34 = bit32.rshift(v33, 13)
	local v35 = bit32.bxor(v33, v34)
	local v36 = v35 % 65536
	local v37 = v35 / 65536
	local v38 = math.floor(v37) % 65536
	local v39 = (v36 * 44597 + (v36 * 49842 + v38 * 44597) % 65536 * 65536) % 4294967296
	local v40 = bit32.rshift(v39, 16)
	return bit32.bxor(v39, v40) % 4294967296
end

