					local TargetChar = TargetPlayer.Character
					local TargetHead = TargetChar:FindFirstChild("Head")
					local TargetHum = TargetChar:FindFirstChild("Humanoid")
					
					if TargetHead and TargetHum and TargetHead.Parent and TargetHum.Parent then
						SecureFire({
							Type = "Input",
							Hit = TargetHead,
							Limb = Character:FindFirstChild("Left Arm"),
							Position = TargetHead.Position,
							Humanoid = TargetHum
						})
