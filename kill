local IsMinimized = false
local OriginalSize = MainFrame.Size

Title.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		local clickTime = os.clock()
		local connection
		connection = UserInputService.InputBegan:Connect(function(nextInput)
			if nextInput.UserInputType == Enum.UserInputType.MouseButton1 or nextInput.UserInputType == Enum.UserInputType.Touch then
				if os.clock() - clickTime < 0.3 then
					IsMinimized = not IsMinimized
					if IsMinimized then
						ContentFrame.Visible = false
						MainFrame.Size = UDim2.new(0, OriginalSize.X.Offset, 0, 35)
					else
						MainFrame.Size = OriginalSize
						ContentFrame.Visible = true
					end
				end
				connection:Disconnect()
			end
		end)
		task.delay(0.3, function()
			if connection then connection:Disconnect() end
		end)
	end
end)

local function GetClosestTarget()
	if not Character or not Character:FindFirstChild("HumanoidRootPart") then return nil end
	
	local ClosestPlayer = nil
	local MinDistance = 25
	local LocalPos = Character.HumanoidRootPart.Position
	
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") then
			local Char = p.Character
			local Hum = Char.Humanoid
			local TargetPart = Char:FindFirstChild("HumanoidRootPart") or Char:FindFirstChild("Head")
			
			if TargetPart and Hum.Health > 0 and not Char:FindFirstChild("ForceField") and not Char:GetAttribute("Shield") then
				local Distance = (TargetPart.Position - LocalPos).Magnitude
				if Distance < MinDistance then
					MinDistance = Distance
					ClosestPlayer = p
				end
			end
		end
	end
	return ClosestPlayer
end

