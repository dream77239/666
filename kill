			end
		end)
	else
		ToggleBtn.Text = "OFF"
		ToggleBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
		if RunningLoop then
			task.cancel(RunningLoop)
			RunningLoop = nil
		end
	end
end)

