local lastTargetUpdate = 0
local function updateTarget()
    local now = os.clock()
    if now - lastTargetUpdate < 0.2 then return end
    lastTargetUpdate = now
    
    local closest, dist = nil, math.huge
    local camCF = Camera.CFrame
    local camPos = camCF.Position
    local pool = GetTargetsPool()
    
    for i = 1, #pool do
        local c = pool[i]
        local head = c:FindFirstChild("Head")
        local hum = c:FindFirstChildOfClass("Humanoid")
        if head and hum and hum.Health > 0 then
            local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
            if onScreen then
                local fovDist = (Vector2.new(screenPos.X, screenPos.Y) - FOV_Circle.Position).Magnitude
                if fovDist <= FOVSize then
                    if WallCheckEnabled then
                        local localChar = GetLocalCharacter()
                        if not IsVisible(camPos, head.Position, c, localChar) then
                            continue
                        end
                    end
                    if fovDist < dist then
                        dist = fovDist
                        closest = c
                    end
                end
            end
        end
    end
    cachedTarget = closest
end

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if not checkcaller() then
        if (method == "FireServer" or method == "InvokeServer") then
            if self == DamageEvent and NoFallDamageEnabled then
                return nil
            end
            if self == RagdollEvent and NoRagdollEnabled then
                return nil
            end
        end
        
        if self == Workspace and (method == "Raycast" or method == "FindPartOnRay") then
            if SilentAimEnabled and cachedTarget then
                local origin, direction
                if method == "Raycast" then
                    origin, direction = args[1], args[2]
                else
                    local ray = args[1]
                    if typeof(ray) == "Ray" then
                        origin, direction = ray.Origin, ray.Direction
                    end
                end
                if origin and direction and typeof(direction) == "Vector3" then
                    local camPos = Camera.CFrame.Position
                    local distFromCam = (origin - camPos).Magnitude
                    if distFromCam < 10 and direction.Magnitude > 30 then
                        if Camera.CFrame.LookVector:Dot(direction.Unit) > 0.4 then
                            local roll = math.random(1, 100)
                            if roll <= HitChance then
                                local targetPart = GetTargetPart(cachedTarget)
                                if targetPart then
                                    return {
                                        Instance = targetPart,
                                        Position = targetPart.Position,
                                        Normal = (targetPart.Position - origin).Unit,
                                        Material = Enum.Material.Plastic
                                    }
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return oldNamecall(self, ...)
end)

