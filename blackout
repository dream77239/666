                    local targetRoot = object:FindFirstChild("HumanoidRootPart")
                    if head and targetRoot then
                        local pos = targetRoot.Position
                        local dist = (localRoot.Position - pos).Magnitude
                        if dist <= 22 then
                            task.spawn(function()
                                MeleeSwingEvent:InvokeServer()
                                MeleeHitEvent:FireServer(head, vector.create(pos.X, pos.Y, pos.Z))
                            end)
                        end
                    end
                end
            end
        end
    end
end)

