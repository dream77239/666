local function IsValid(object)
    if not object or not object:IsA("Model") then return false end
    if object == LocalPlayer.Character then return false end
    if object.Name == LocalPlayer.Name then return false end
    
    local humanoid = object:FindFirstChildOfClass("Humanoid")
    local root = object:FindFirstChild("HumanoidRootPart")
    local head = object:FindFirstChild("Head")
    
    if not humanoid or not root or not head or humanoid.Health <= 0 then return false end
    if object:FindFirstChild("ForceField") then return false end
    
    return true
end

local function GetLocalCharacter()
    local char = LocalPlayer.Character
    if char and char.Parent == CharsFolder then
        return char
    end
    for _, child in ipairs(CharsFolder:GetChildren()) do
        if child:IsA("Model") and child.Name == LocalPlayer.Name then
            return child
        end
    end
    return char
end

local function ScanForNPCs(parent, pool)
    if not parent then return end
    local children = parent:GetChildren()
    for i = 1, #children do
        local obj = children[i]
        if IsValid(obj) then
            table.insert(pool, obj)
        end
        if obj:IsA("Folder") or obj:IsA("Model") or obj:IsA("Configuration") then
            ScanForNPCs(obj, pool)
        end
    end
end

local function GetTargetsPool()
    local pool = {}
    if TargetType == "NPCs" then
        local custom = NPCsFolder:FindFirstChild("Custom")
        if custom then
            local children = custom:GetChildren()
            for i = 1, #children do
                local obj = children[i]
                if IsValid(obj) then table.insert(pool, obj) end
            end
        end
        
        local hostile = NPCsFolder:FindFirstChild("Hostile")
        if hostile then
            local children = hostile:GetChildren()
            for i = 1, #children do
                local obj = children[i]
                if IsValid(obj) then table.insert(pool, obj) end
            end
        end

        local location = ActiveTasksFolder:FindFirstChild("Location")
        if location then
            ScanForNPCs(location, pool)
        end
    else
        local players = Players:GetPlayers()
        for i = 1, #players do
            local player = players[i]
            if player ~= LocalPlayer and player.Character and IsValid(player.Character) then
                table.insert(pool, player.Character)
            end
        end
    end
    return pool
end

local function IsVisible(startPos, targetPos, targetInstance, localChar)
    local direction = targetPos - startPos
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {localChar, CoreGui}
    raycastParams.IgnoreWater = true
    
    local result = workspace:Raycast(startPos, direction, raycastParams)
    if result then
        if result.Instance:IsDescendantOf(targetInstance) then
            return true
        end
        return false
    end
    return true
end

local function GetTargetPart(character)
    if not character then return nil end
    if HitPartSelection == "Head" then
        return character:FindFirstChild("Head")
    elseif HitPartSelection == "Torso" then
        return character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso") or character:FindFirstChild("HumanoidRootPart")
    elseif HitPartSelection == "Left Arm" then
        return character:FindFirstChild("Left Arm") or character:FindFirstChild("LeftUpperArm") or character:FindFirstChild("LeftHand")
    elseif HitPartSelection == "Right Arm" then
        return character:FindFirstChild("Right Arm") or character:FindFirstChild("RightUpperArm") or character:FindFirstChild("RightHand")
    elseif HitPartSelection == "Left Leg" then
        return character:FindFirstChild("Left Leg") or character:FindFirstChild("LeftLowerLeg") or character:FindFirstChild("LeftFoot")
    elseif HitPartSelection == "Right Leg" then
        return character:FindFirstChild("Right Leg") or character:FindFirstChild("RightLowerLeg") or character:FindFirstChild("RightFoot")
    elseif HitPartSelection == "Random" then
        local parts = {}
        local head = character:FindFirstChild("Head")
        local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso") or character:FindFirstChild("HumanoidRootPart")
        local la = character:FindFirstChild("Left Arm") or character:FindFirstChild("LeftUpperArm")
        local ra = character:FindFirstChild("Right Arm") or character:FindFirstChild("RightUpperArm")
        local ll = character:FindFirstChild("Left Leg") or character:FindFirstChild("LeftLowerLeg")
        local rl = character:FindFirstChild("Right Leg") or character:FindFirstChild("RightLowerLeg")
        
        if head then table.insert(parts, head) end
        if torso then table.insert(parts, torso) end
        if la then table.insert(parts, la) end
        if ra then table.insert(parts, ra) end
        if ll then table.insert(parts, ll) end
        if rl then table.insert(parts, rl) end
        
        if #parts > 0 then
            return parts[math.random(1, #parts)]
        end
    end
    return character:FindFirstChild("HumanoidRootPart")
end

local function GetClosest(maxDistance)
    local closest = nil
    local shortestDistance = maxDistance or math.huge
    local localChar = GetLocalCharacter()
    if not localChar then return nil end
    local localRoot = localChar:FindFirstChild("HumanoidRootPart")
    if not localRoot then return nil end

    local pool = GetTargetsPool()
    for i = 1, #pool do
        local object = pool[i]
        local targetRoot = object:FindFirstChild("HumanoidRootPart")
        if targetRoot then
            local distance = (localRoot.Position - targetRoot.Position).Magnitude
            if distance < shortestDistance then
                shortestDistance = distance
                closest = object
            end
        end
    end
    return closest
end

local function GetMagazineValue()
    local localChar = GetLocalCharacter()
    if localChar then
        local gunStatus = localChar:FindFirstChild("GunStatus", true)
        if gunStatus then
            local magAttribute = gunStatus:GetAttribute("Magazine")
            if magAttribute then
                return magAttribute
            end
            local magazine = gunStatus:FindFirstChild("Magazine")
            if magazine and (magazine:IsA("ValueBase") or magazine:IsA("NumberValue") or magazine:IsA("IntValue")) then
                return magazine.Value
            end
        end
    end
    return nil
end

local function ApplyConfigModifications()
    local gc = getgc(true)
    for i = 1, #gc do
        local v = gc[i]
        if type(v) == "table" then
            local firing = v.Firing
            if firing and type(firing) == "table" and firing.Recoil ~= nil then
                if GCNorecoilEnabled then
                    firing.Recoil = NumberRange.new(0, 0)
                    firing.Shake = 0
                    firing.Kickback = 0
                    firing.AimedKickback = 0
                end
                if GCRPMEnabled then
                    v.Automatic = true
                    firing.RPM = 9999
                end
            end
        end
    end
end

