local function getFrontPosition(part)
    if not part:IsA("BasePart") then return part.Position end
    local size = part.Size
    local maxDim = math.max(size.X, size.Y, size.Z)
    if maxDim == size.Z then
        return (part.CFrame * CFrame.new(0, 0, -size.Z / 2)).Position
    elseif maxDim == size.X then
        return (part.CFrame * CFrame.new(-size.X / 2, 0, 0)).Position
    else
        return (part.CFrame * CFrame.new(0, -size.Y / 2, 0)).Position
    end
end

local function getPlayerTeamValue(player)
    if not player then return nil end
    
    local customTeam = player:FindFirstChild("team") or player:FindFirstChild("Team") or player:FindFirstChild("PlayerTeam") or player:FindFirstChild("CustomTeam")
    if customTeam then
        return tostring(customTeam.Value):lower()
    end
    
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local teamStat = leaderstats:FindFirstChild("team") or leaderstats:FindFirstChild("Team")
        if teamStat then
            return tostring(teamStat.Value):lower()
        end
    end

    local char = player.Character
    if char then
        local customTeamChar = char:FindFirstChild("team") or char:FindFirstChild("Team")
        if customTeamChar then
            return tostring(customTeamChar.Value):lower()
        end
    end
    
    local attr = player:GetAttribute("team") or player:GetAttribute("Team") or player:GetAttribute("PlayerTeam")
    if attr then
        return tostring(attr):lower()
    end
    
    if player.Team then
        return tostring(player.Team.Name):lower()
    end
    
    return nil
end

local function checkIsFFA()
    local firstTeam = nil
    local allSame = true
    local playersList = Players:GetPlayers()
    
    if #playersList <= 1 then
        return true
    end
    
    for _, p in ipairs(playersList) do
        local t = getPlayerTeamValue(p)
        if t and t ~= "" and t ~= "nil" then
            if firstTeam == nil then
                firstTeam = t
            elseif t ~= firstTeam then
                allSame = false
                break
            end
        else
            allSame = false
            break
        end
    end
    
    if firstTeam == nil then
        return true
    end
    
    return allSame
end

local function checkWall(fromPos, toPos, targetChar)
    local direction = toPos - fromPos
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    
    local ignoreList = {LocalPlayer.Character, workspace:FindFirstChild(LocalPlayer.Name), cam, workspace.CurrentCamera}
    raycastParams.FilterDescendantsInstances = ignoreList
    raycastParams.IgnoreWater = true
    
    local result = workspace:Raycast(fromPos, direction, raycastParams)
    if result then
        local hitPart = result.Instance
        if hitPart and not hitPart:IsDescendantOf(targetChar) and hitPart.CanCollide and hitPart.Transparency < 1 then
            return false
        end
    end
    return true
end

