    while true do
        local myWeapon = getCurrentWeapon()
        
        if not myWeapon then
            updateHUD(nil)
            task.wait(0.1)
            continue
        end

        local delayTime = getWeaponFireRate(myWeapon)
        
        if not delayTime then
            updateHUD(nil)
            task.wait(0.1)
            continue
        end
        
        task.wait(delayTime)

        if not config.auraEnabled then 
            updateHUD(nil)
            continue 
        end

        local myCharacter = LocalPlayer.Character
        if not myCharacter or not myCharacter:FindFirstChild("HumanoidRootPart") then 
            updateHUD(nil)
            continue 
        end

        local myPos = myCharacter.HumanoidRootPart.Position
        local closestTarget = nil
        local targetPlayerObj = nil
        local shortestDistance = ATTACK_RANGE
        
        local isFFA = checkIsFFA()
        local myTeam = getPlayerTeamValue(LocalPlayer)

        for _, targetPlayer in ipairs(Players:GetPlayers()) do
            if targetPlayer == LocalPlayer then continue end
            
            if config.teamCheckEnabled and not isFFA and myTeam and myTeam ~= "" and myTeam ~= "nil" then
                local targetTeam = getPlayerTeamValue(targetPlayer)
                if targetTeam and targetTeam == myTeam then
                    continue
                end
            end

            local targetChar = targetPlayer.Character
            if targetChar then
                local humanoid = targetChar:FindFirstChildOfClass("Humanoid")
                if humanoid and humanoid.Health <= 0 then continue end
                if targetChar:FindFirstChildOfClass("ForceField") then continue end

                local targetHead = targetChar:FindFirstChild("Head")
                local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")

                if targetHead and targetRoot then
                    local distance = (targetRoot.Position - myPos).Magnitude
                    if distance < shortestDistance then
                        if config.wallCheckEnabled then
                            local originPos = myCharacter.HumanoidRootPart.Position
                            local dynamicBarrel = getDynamicBarrel(myWeapon.Name)
                            if dynamicBarrel and dynamicBarrel:IsA("BasePart") then
