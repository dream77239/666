local function getPlayerTeamValue(player)
    if not player then return nil end
    local customTeam = player:FindFirstChild("team") or player:FindFirstChild("Team") or player:FindFirstChild("PlayerTeam") or player:FindFirstChild("CustomTeam")
    if customTeam then return tostring(customTeam.Value):lower() end
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local teamStat = leaderstats:FindFirstChild("team") or leaderstats:FindFirstChild("Team")
        if teamStat then return tostring(teamStat.Value):lower() end
    end
    local char = player.Character
    if char then
        local customTeamChar = char:FindFirstChild("team") or char:FindFirstChild("Team")
        if customTeamChar then return tostring(customTeamChar.Value):lower() end
    end
    local attr = player:GetAttribute("team") or player:GetAttribute("Team") or player:GetAttribute("PlayerTeam")
    if attr then return tostring(attr):lower() end
    if player.Team then return tostring(player.Team.Name):lower() end
    return nil
end

local function checkIsFFA()
    local firstTeam = nil
    local allSame = true
    local playersList = Players:GetPlayers()
    if #playersList <= 1 then return true end
    for _, p in ipairs(playersList) do
        local t = getPlayerTeamValue(p)
        if t and t ~= "" and t ~= "nil" then
            if firstTeam == nil then firstTeam = t
            elseif t ~= firstTeam then allSame = false break end
        else allSame = false break end
    end
    if firstTeam == nil then return true end
    return allSame
end

local function checkWall(fromPos, toPos, targetChar)
    local direction = toPos - fromPos
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, cam, workspace.CurrentCamera}
    raycastParams.IgnoreWater = true
    local result = workspace:Raycast(fromPos, direction, raycastParams)
    if result then
        local hitPart = result.Instance
        if hitPart and not hitPart:IsDescendantOf(targetChar) and hitPart.CanCollide and hitPart.Transparency < 1 then
            return false
        end
    end
    return true
end

local function getTargetPart(character)
    local selection = config.targetPart
    local parts = {}
    if selection == "Head" then
        return character:FindFirstChild("Head")
    elseif selection == "Torso" then
        return character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    elseif selection == "LeftArm" then
        return character:FindFirstChild("Left Arm") or character:FindFirstChild("LeftUpperArm")
    elseif selection == "RightArm" then
        return character:FindFirstChild("Right Arm") or character:FindFirstChild("RightUpperArm")
    elseif selection == "LeftLeg" then
        return character:FindFirstChild("Left Leg") or character:FindFirstChild("LeftUpperLeg")
    elseif selection == "RightLeg" then
        return character:FindFirstChild("Right Leg") or character:FindFirstChild("RightUpperLeg")
    elseif selection == "Random" then
        local possible = {"Head", "HumanoidRootPart", "Left Arm", "Right Arm", "Left Leg", "Right Leg"}
        for _, name in ipairs(possible) do
            local p = character:FindFirstChild(name)
            if p then table.insert(parts, p) end
        end
        if #parts > 0 then
            return parts[math.random(1, #parts)]
        end
    end
    return character:FindFirstChild("Head")
end

local function getCurrentWeapon()
    local myCharacter = LocalPlayer.Character
    if not myCharacter then return nil end
    for _, child in ipairs(myCharacter:GetChildren()) do
        if child:IsA("Tool") then
            if child:FindFirstChild("GunServer") or child:FindFirstChild("Handle") then
                return child
            end
        end
    end
    return nil
end

local function getDynamicBarrel(weaponName)
    local folder = workspace:FindFirstChild("RocketHawkFlash_YT")
    if not folder then return nil end
    local gunModel = folder:FindFirstChild(weaponName)
    if gunModel then
        local parts = gunModel:FindFirstChild("Parts")
        if parts then
            return parts:FindFirstChild("Barrel")
        end
    end
    return nil
end

local function getFrontPosition(part)
    if not part:IsA("BasePart") then return part.Position end
    local size = part.Size
    local maxDim = math.max(size.X, size.Y, size.Z)
    if maxDim == size.Z then
        return (part.CFrame * CFrame.new(0, 0, -size.Z / 2)).Position
    elseif maxDim == size.X then
        return (part.CFrame * CFrame.new(-size.X / 2, 0, 0)).Position
    else
        return (part.CFrame * CFrame.new(0, -size.Y / 2, 0)).Position
    end
end

local function getCurrentWeaponMuzzle()
    local weapon = getCurrentWeapon()
    if weapon then
        local dynamicBarrel = getDynamicBarrel(weapon.Name)
        if dynamicBarrel and dynamicBarrel:IsA("BasePart") then
            return getFrontPosition(dynamicBarrel)
        else
            local muzzle = weapon:FindFirstChild("Muzzle") or weapon:FindFirstChild("Handle")
            if muzzle then return getFrontPosition(muzzle) end
        end
    end
    local myCharacter = LocalPlayer.Character
    local head = myCharacter and myCharacter:FindFirstChild("Head")
    if head then return head.Position end
    return nil
end

local function updateTarget()
    if not config.silentAimEnabled then
        cachedTarget = nil
        return
    end
    local closest, dist = nil, math.huge
    local camCF = Camera.CFrame
    local camPos = camCF.Position
    local isFFA = checkIsFFA()
    local myTeam = getPlayerTeamValue(LocalPlayer)
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            if config.teamCheckEnabled and not isFFA and myTeam and myTeam ~= "" and myTeam ~= "nil" then
                local targetTeam = getPlayerTeamValue(p)
                if targetTeam and targetTeam == myTeam then continue end
            end
            local c = p.Character
            if c then
                local hum = c:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 and not c:FindFirstChild("ForceField") then
                    local targetPartInstance = getTargetPart(c)
                    if targetPartInstance then
                        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPartInstance.Position)
                        if onScreen then
                            local mousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                            local fovDist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                            if fovDist <= config.fovSize and fovDist < dist then
                                if config.wallCheckEnabled then
                                    local originPos = getCurrentWeaponMuzzle() or camPos
                                    if not checkWall(originPos, targetPartInstance.Position, c) then
                                        continue
                                    end
                                end
                                dist = fovDist
                                closest = targetPartInstance
                            end
                        end
                    end
                end
            end
        end
    end
    cachedTarget = closest
    if closest and config.hudEnabled then
        local targetPlayer = Players:GetPlayerFromCharacter(closest.Parent)
        if targetPlayer then
            updateHUD(targetPlayer)
        end
    else
        updateHUD(nil)
    end
end

RunService.RenderStepped:Connect(function()
    if tick() - lastUpdate > updateDelay then
        lastUpdate = tick()
        updateTarget()
    end
    
    if config.silentAimEnabled and config.snapLineEnabled and cachedTarget and cachedTarget.Parent then
        local torso = cachedTarget.Parent:FindFirstChild("HumanoidRootPart") or cachedTarget.Parent:FindFirstChild("Torso") or cachedTarget.Parent:FindFirstChild("UpperTorso")
        if torso then
            local screenPos, onScreen = Camera:WorldToViewportPoint(torso.Position)
            if onScreen then
                local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                Snap_Line.From = center
                Snap_Line.To = Vector2.new(screenPos.X, screenPos.Y)
                Snap_Line.Visible = true
            else
                Snap_Line.Visible = false
            end
        else
            Snap_Line.Visible = false
        end
    else
        Snap_Line.Visible = false
    end
end)

local old
old = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if not checkcaller() and self == Workspace and (method == "Raycast" or method == "FindPartOnRay") then
        if config.silentAimEnabled and cachedTarget then
            if math.random(1, 100) <= config.hitChance then
                local args = {...}
                local origin, direction
                if method == "Raycast" then
                    origin, direction = args[1], args[2]
                else
                    local ray = args[1]
                    if typeof(ray) == "Ray" then
                        origin, direction = ray.Origin, ray.Direction
                    end
                end
                if origin and direction then
                    local customOrigin = getCurrentWeaponMuzzle() or origin
                    if method == "Raycast" then
                        return {
                            Instance = cachedTarget,
                            Position = cachedTarget.Position,
                            Normal = (cachedTarget.Position - customOrigin).Unit,
                            Material = Enum.Material.Plastic
                        }
                    else
                        return cachedTarget, cachedTarget.Position, (cachedTarget.Position - customOrigin).Unit, Enum.Material.Plastic
                    end
                end
            end
        end
    end
    return old(self, ...)
end)

