local function updateHUD(targetPlayer)
    if not config.hudEnabled then
        mainFrame.Visible = false
        lastTarget = nil
        return
    end

    if config.hudPreview and not targetPlayer then
        mainFrame.Visible = true
        if lastTarget ~= "Preview" then
            lastTarget = "Preview"
            nameLabel.Text = "Preview Target"
            userLabel.Text = "@PreviewUser"
            avatarImage.Image = "rbxthumb://type=AvatarHeadShot&id=" .. LocalPlayer.UserId .. "&w=150&h=150"
            healthBar.Size = UDim2.new(0.75, 0, 1, 0)
            damageBar.Size = UDim2.new(0.75, 0, 1, 0)
            pctLabel.Text = "75%"
            healthBar.BackgroundColor3 = Color3.fromRGB(0, 220, 120)
        end
        return
    end

    if not targetPlayer then
        mainFrame.Visible = false
        lastTarget = nil
        return
    end

    local char = targetPlayer.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        mainFrame.Visible = false
        lastTarget = nil
        return
    end

    mainFrame.Visible = true

    if lastTarget ~= targetPlayer then
        lastTarget = targetPlayer
        nameLabel.Text = targetPlayer.DisplayName or targetPlayer.Name
        userLabel.Text = "@" .. targetPlayer.Name
        avatarImage.Image = "rbxthumb://type=AvatarHeadShot&id=" .. targetPlayer.UserId .. "&w=150&h=150"
        lastHealth = humanoid.Health
        
        local hpRatio = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
        healthBar.Size = UDim2.new(hpRatio, 0, 1, 0)
        damageBar.Size = UDim2.new(hpRatio, 0, 1, 0)
        pctLabel.Text = math.round(hpRatio * 100) .. "%"
    end

    local currentHealth = humanoid.Health
    local maxHealth = humanoid.MaxHealth
    local hpRatio = math.clamp(currentHealth / maxHealth, 0, 1)
    
    pctLabel.Text = math.round(hpRatio * 100) .. "%"

    if currentHealth < lastHealth then
        if damageTween then damageTween:Cancel() end
        
        healthBar.Size = UDim2.new(hpRatio, 0, 1, 0)
        
        task.spawn(function()
            task.wait(0.1)
            damageTween = TweenService:Create(damageBar, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(hpRatio, 0, 1, 0)})
            damageTween:Play()
        end)
    elseif currentHealth > lastHealth or healthBar.Size.X.Scale ~= hpRatio then
        if damageTween then damageTween:Cancel() end
        healthBar.Size = UDim2.new(hpRatio, 0, 1, 0)
        damageBar.Size = UDim2.new(hpRatio, 0, 1, 0)
    end

    lastHealth = currentHealth

    if hpRatio >= 0.6 then
        healthBar.BackgroundColor3 = Color3.fromRGB(0, 220, 120)
    elseif hpRatio >= 0.25 then
        healthBar.BackgroundColor3 = Color3.fromRGB(255, 140, 0)
    else
        healthBar.BackgroundColor3 = Color3.fromRGB(220, 0, 40)
    end
end

