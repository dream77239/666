                                    originPos = getFrontPosition(muzzle)
                                end
                            end
                            if not checkWall(originPos, targetHead.Position, targetChar) then
                                continue
                            end
                        end

                        shortestDistance = distance
                        closestTarget = {head = targetHead, root = targetRoot}
                        targetPlayerObj = targetPlayer
                    end
                end
            end
