local function getWeaponFireRate(weapon)
    local folder = workspace:FindFirstChild(LocalPlayer.Name)
    if folder then
        local targetGunModel = nil
        local weaponCleanName = weapon.Name:gsub("%s+", ""):lower()
        
        for _, child in ipairs(folder:GetChildren()) do
            local childCleanName = child.Name:gsub("%s+", ""):lower()
            if childCleanName:find(weaponCleanName) or weaponCleanName:find(childCleanName) then
                targetGunModel = child
                break
            end
        end
        
        if targetGunModel then
            local settingModule = targetGunModel:FindFirstChild("Setting")
            if not settingModule then
                for _, desc in ipairs(targetGunModel:GetDescendants()) do
                    if desc:IsA("ModuleScript") and desc.Name == "Setting" then
                        settingModule = desc
                        break
                    end
                end
            end
            
            if settingModule and settingModule:IsA("ModuleScript") then
                local success, result = pcall(require, settingModule)
                if success and type(result) == "table" then
                    for k, v in pairs(result) do
                        if tostring(k):lower():find("firerate") and type(v) == "number" then
                            return v
                        end
                    end
                    if rawget(result, "FireRates") and type(result.FireRates) == "table" then
                        return result.FireRates[1]
                    end
                end
                
                if env and type(env.isViableDecompileScript) == "function" and env.isViableDecompileScript(settingModule) then
                    if type(env.decompile) == "function" then
                        local decompiledSuccess, code = pcall(env.decompile, settingModule)
                        if decompiledSuccess and type(code) == "string" then
                            local lowerCode = code:lower()
                            local match = lowerCode:match("firerate%s*[:=]%s*([%d%.]+)") or lowerCode:match("%[[\"']firerate[\"']%]%s*=%s*([%d%.]+)")
                            if match then
                                local num = tonumber(match)
                                if num then return num end
                            end
                        end
                    end
                end
                
                local s, fields = pcall(getgc)
                if s and type(fields) == "table" then
                    for _, v in pairs(fields) do
                        if type(v) == "table" then
                            local rawFR = rawget(v, "FireRate") or rawget(v, "fireRate") or rawget(v, "FIRERATE")
                            if type(rawFR) == "number" then
                                return rawFR
                            end
                            local rawFRs = rawget(v, "FireRates") or rawget(v, "fireRates")
                            if type(rawFRs) == "table" and type(rawFRs[1]) == "number" then
                                return rawFRs[1]
                            end
                            for key, val in pairs(v) do
                                if type(key) == "string" and key:lower():find("firerate") and type(val) == "number" then
                                    return val
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    local modules = ReplicatedStorage:FindFirstChild("Modules") or ReplicatedStorage
    for _, v in pairs(modules:GetDescendants()) do
        if v:IsA("ModuleScript") and (v.Name:lower():find(weapon.Name:lower()) or v.Name:find("Setting")) then
            local success, result = pcall(require, v)
            if success and type(result) == "table" then
                for k, v_val in pairs(result) do
                    if tostring(k):lower():find("firerate") and type(v_val) == "number" then
                        return v_val
                    end
                end
                if rawget(result, "FireRates") and type(result.FireRates) == "table" then
                    return result.FireRates[1]
                end
            end
        end
    end

    local s, fields = pcall(getgc)
    if s and type(fields) == "table" then
        for _, v in pairs(fields) do
            if type(v) == "table" then
                for key, val in pairs(v) do
                    if type(key) == "string" and key:lower():find("firerate") and type(val) == "number" then
                        return val
                    end
                end
            end
        end
    end

    return nil
end

