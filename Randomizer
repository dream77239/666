    for player, objects in pairs(espObjects) do
        local char = player.Character
        if not char or not char.Parent then
            removeESP(player)
            continue
        end

        if not objects.Highlight or not objects.Highlight.Parent then
            createESP(player)
            objects = espObjects[player]
            if not objects then continue end
        end

        if config.espEnabled then
            objects.Highlight.Enabled = true
            if isFFA then
                objects.Highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
                objects.Highlight.FillColor = Color3.fromRGB(255, 0, 0)
            else
                local targetTeam = getPlayerTeamValue(player)
                if myTeam and targetTeam and myTeam == targetTeam and myTeam ~= "" and myTeam ~= "nil" then
                    objects.Highlight.OutlineColor = Color3.fromRGB(0, 255, 0)
                    objects.Highlight.FillColor = Color3.fromRGB(0, 255, 0)
                else
                    objects.Highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
                    objects.Highlight.FillColor = Color3.fromRGB(255, 0, 0)
                end
            end
        else
            objects.Highlight.Enabled = false
        end

        local textStr = ""
        local charRoot = char:FindFirstChild("HumanoidRootPart")
        local humanoid = char:FindFirstChildOfClass("Humanoid")

        if config.espName then
            textStr = textStr .. (player.DisplayName or player.Name) .. "\n"
        end

        if config.espHealth and humanoid then
            textStr = textStr .. "HP: " .. math.round(humanoid.Health) .. "/" .. math.round(humanoid.MaxHealth) .. "\n"
        end

        if config.espDistance and myRoot and charRoot then
            local dist = math.round((myRoot.Position - charRoot.Position).Magnitude)
            textStr = textStr .. "Dist: " .. dist .. " studs\n"
        end

        if objects.BillboardGui and objects.TextLabel then
            if textStr ~= "" and (config.espName or config.espHealth or config.espDistance) then
                objects.BillboardGui.Enabled = true
                objects.TextLabel.Text = textStr
            else
                objects.BillboardGui.Enabled = false
            end

            if not objects.BillboardGui.Parent or not objects.BillboardGui.Parent:IsDescendantOf(char) then
                local head = char:FindFirstChild("Head")
                if head then objects.BillboardGui.Parent = head end
            end
        end
    end
end

