local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer

local config = {
    handsChams = false,
    bodyChams = false,
    weaponChams = false,
    handsColor = {255, 255, 255},
    bodyColor = {255, 255, 255},
    weaponColor = {255, 255, 255}
}

local originalMaterials = {}
local originalColors = {}

local function loadConfig()
    if isfile and isfile("chams_config.json") then
        local success, result = pcall(function()
            return HttpService:JSONDecode(readfile("chams_config.json"))
        end)
        if success and type(result) == "table" then
            for k, v in pairs(result) do
                config[k] = v
            end
        end
    end
end

local function saveConfig()
    if writefile then
        pcall(function()
            writefile("chams_config.json", HttpService:JSONEncode(config))
        end)
    end
end

loadConfig()

local function isHand(part)
    local name = part.Name
    return name == "LeftHand" or name == "RightHand" or name == "Left Arm" or name == "Right Arm"
end

local function isBody(part)
    local name = part.Name
    return part:IsA("BasePart") and not isHand(part)
end

local function saveOriginal(part)
    if not originalMaterials[part] then
        originalMaterials[part] = part.Material
    end
    if not originalColors[part] then
        originalColors[part] = part.Color
    end
end

local function restorePart(part)
    if originalMaterials[part] then
        part.Material = originalMaterials[part]
        originalMaterials[part] = nil
    end
    if originalColors[part] then
        part.Color = originalColors[part]
        originalColors[part] = nil
    end
end

local function updateChams()
    local char = LocalPlayer.Character
    if not char then return end

    local hColor = Color3.fromRGB(unpack(config.handsColor))
    local bColor = Color3.fromRGB(unpack(config.bodyColor))
    local wColor = Color3.fromRGB(unpack(config.weaponColor))

    for _, v in ipairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            if v:IsDescendantOf(char) and not v.Parent:IsA("Tool") then
                if isHand(v) then
                    if config.handsChams then
                        saveOriginal(v)
                        v.Material = Enum.Material.ForceField
                        v.Color = hColor
                    else
                        restorePart(v)
                    end
                elseif isBody(v) then
                    if config.bodyChams then
                        saveOriginal(v)
                        v.Material = Enum.Material.ForceField
                        v.Color = bColor
                    else
                        restorePart(v)
                    end
                end
            elseif v.Parent:IsA("Tool") or v:FindFirstAncestorOfClass("Tool") then
                if config.weaponChams then
                    saveOriginal(v)
                    v.Material = Enum.Material.ForceField
                    v.Color = wColor
                else
                    restorePart(v)
                end
            end
        end
    end

    local folder = Workspace:FindFirstChild("RocketHawkFlash_YT")
    if folder then
        for _, gunModel in ipairs(folder:GetChildren()) do
            for _, v in ipairs(gunModel:GetDescendants()) do
                if v:IsA("BasePart") then
                    if config.weaponChams then
                        saveOriginal(v)
                        v.Material = Enum.Material.ForceField
                        v.Color = wColor
                    else
                        restorePart(v)
                    end
                end
            end
        end
    end
end

RunService.RenderStepped:Connect(updateChams)

