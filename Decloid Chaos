									hitModel = {target}
								},
								{
									EnergyUssage = 0,
									MeleeHitboxDistance = 3,
									Firerate = 0.32,
									MeleeDelay = 0.1,
									MeleeHitboxSize = Vector3.new(9, 7, 4),
									Damage = 20.16
								},
								{
									Vector3.new(2, 1, 1)
								}
							}
							sendActions:FireServer(unpack(args))
						end
					end
				end
			end
		end
	end
end)

task.spawn(function()
	while true do
		task.wait(0.01)
		if rangedActive then
			local weapon = getWeapon()
			if weapon then
				local settings = weapon:FindFirstChild("Settings")
				local sendActions = weapon:FindFirstChild("SendActions")
				
				if settings and sendActions then
					local targets = getRangedTargets()
					if #targets > 0 then
						local count = 0
						for _, target in pairs(targets) do
							if not rangedActive or getWeapon() ~= weapon then break end
							if count >= 2 then break end
							if isAlive(target.model) then
								count = count + 1
								local startMuzzle = getMuzzlePosition(weapon)
								local pos = target.part.Position
								
								createVisualEffects(startMuzzle, pos, target.part)

								local args = {
									"Damage",
									{
										hitPart = target.part,
										hitModel = target.model,
										ImpactPosition = vector.create(pos.X, pos.Y, pos.Z)
									},
									{
										Firerate = settings:GetAttribute("Firerate") or 0.1,
										ProjectileAcceleration = settings:GetAttribute("ProjectileAcceleration") or vector.zero,
										ProjectileVelocity = settings:GetAttribute("ProjectileVelocity") or 1000,
										EnergyUssage = settings:GetAttribute("EnergyUssage") or 0,
										Spread = settings:GetAttribute("Spread") or 0,
										Damage = settings:GetAttribute("Damage") or 1
									}
								}
								sendActions:FireServer(unpack(args))
							end
						end
					end
				end
			end
		end
	end
end)

