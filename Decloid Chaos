local currentBeamColor = Color3.fromRGB(config.BeamColor[1], config.BeamColor[2], config.BeamColor[3])

local function getWeapon()
	local char = LocalPlayer.Character
	if not char then return nil end
	for _, child in pairs(char:GetChildren()) do
		if child:IsA("Tool") and child:FindFirstChild("SendActions") and child:FindFirstChild("Settings") then
			return child
		end
	end
	return nil
end

local function getMeleeWeapon()
	local char = LocalPlayer.Character
	if not char then return nil end
	for _, child in pairs(char:GetChildren()) do
		if child:IsA("Tool") and child:FindFirstChild("SendActions") then
			return child
		end
	end
	return nil
end

local function getMuzzlePosition(weapon)
	local handle = weapon:FindFirstChild("Handle")
	if handle then
		local muzzle = handle:FindFirstChild("Muzzle") or handle:FindFirstChild("Slide")
		if muzzle then
			if muzzle:IsA("Attachment") then
				return muzzle.WorldPosition
			elseif muzzle:IsA("BasePart") then
				return (muzzle.CFrame * CFrame.new(0, 0, -muzzle.Size.Z/2)).Position
			end
		end
		return (handle.CFrame * CFrame.new(0, 0, -handle.Size.Z/2)).Position
	end
	local char = LocalPlayer.Character
	if char and char:FindFirstChild("Right Arm") then
		return char["Right Arm"].Position
	end
	return vector.zero
end

local function isAlive(model)
	local humanoid = model:FindFirstChildOfClass("Humanoid")
	if humanoid and humanoid.Health > 0 then
		return true
	end
	return false
end

local function hasShield(model)
	if model:FindFirstChild("Shield") or model:FindFirstChild("ForceField") or model:FindFirstChild("ShieldValue") or model:FindFirstChild("ShieldProtected") or model:FindFirstChild("BlockingTag") then
		return true
	end
	for _, child in ipairs(model:GetChildren()) do
		if string.find(string.lower(child.Name), "shield") then
			return true
		end
	end
	return false
end

local function getTargets()
	local targets = {}
	local paths = {
		Workspace:FindFirstChild("Entities") and Workspace.Entities:FindFirstChild("Bosses"),
		Workspace:FindFirstChild("Entities") and Workspace.Entities:FindFirstChild("Decloid")
	}
	for _, path in ipairs(paths) do
		if path then
			for _, child in ipairs(path:GetChildren()) do
				if child:IsA("Model") and child:FindFirstChild("HumanoidRootPart") then
					table.insert(targets, child)
				end
			end
		end
	end
	return targets
end

local function getRangedTargets()
	local valid = {}
	local folders = {
		Workspace:FindFirstChild("Entities") and Workspace.Entities:FindFirstChild("Bosses"),
		Workspace:FindFirstChild("Entities") and Workspace.Entities:FindFirstChild("Decloid")
	}
	for _, folder in pairs(folders) do
		if folder then
			for _, ent in pairs(folder:GetChildren()) do
				if ent:IsA("Model") and ent:FindFirstChild("Humanoid") then
					if ent.Humanoid.Health > 0 and not hasShield(ent) then
						local hitbox = ent:FindFirstChild("ProjectileBodyHitbox") or ent:FindFirstChild("Head") or ent:FindFirstChildOfClass("BasePart")
						if hitbox then
							table.insert(valid, {model = ent, part = hitbox})
						end
					end
				end
			end
		end
	end
	return valid
end

local function createVisualEffects(startPos, endPos, targetPart)
	if useSound then
		task.spawn(function()
			local sound = Instance.new("Sound")
			sound.SoundId = "rbxassetid://17148249625"
			sound.Volume = 1.2
			sound.RollOffMaxDistance = 500
			sound.RollOffMinDistance = 20
			sound.RollOffMode = Enum.RollOffMode.Linear
			sound.Parent = targetPart
			sound:Play()
			game.Debris:AddItem(sound, 2)
		end)
	end

	if not useBeam then return end

	local distance = (startPos - endPos).Magnitude
	if distance < 0.1 then return end

	local p1 = Instance.new("Part")
	p1.Anchored = true
	p1.CanCollide = false
	p1.CanTouch = false
	p1.CanQuery = false
	p1.Transparency = 1
	p1.Size = Vector3.new(0.1, 0.1, 0.1)
	p1.CFrame = CFrame.new(startPos)
	p1.Parent = Workspace

	local p2 = Instance.new("Part")
	p2.Anchored = true
	p2.CanCollide = false
	p2.CanTouch = false
	p2.CanQuery = false
	p2.Transparency = 1
	p2.Size = Vector3.new(0.1, 0.1, 0.1)
	p2.CFrame = CFrame.new(endPos)
	p2.Parent = Workspace

	local att1 = Instance.new("Attachment", p1)
	local att2 = Instance.new("Attachment", p2)

	local beam = Instance.new("Beam")
	beam.Attachment0 = att1
	beam.Attachment1 = att2
	beam.Texture = "rbxassetid://446111271"
	beam.Color = ColorSequence.new(currentBeamColor)
	beam.Width0 = 0.4
	beam.Width1 = 0.4
	beam.LightEmission = 1
	beam.LightInfluence = 0
	beam.Transparency = NumberSequence.new(0.3)
	beam.FaceCamera = true
	beam.Parent = p1

	task.delay(2, function()
		local elapsed = 0
		local duration = 0.5
		local connection
		connection = RunService.Heartbeat:Connect(function(dt)
			elapsed = elapsed + dt
			local progress = math.min(elapsed / duration, 1)
			local alpha = 0.3 + (0.7 * progress)
			local currentWidth = 0.4 * (1 - progress)
			
			if beam and beam.Parent then
				beam.Transparency = NumberSequence.new(alpha)
				beam.Width0 = currentWidth
				beam.Width1 = currentWidth
			end
			
			if progress >= 1 then
				connection:Disconnect()
				p1:Destroy()
				p2:Destroy()
			end
		end)
	end)
end

task.spawn(function()
	while true do
		task.wait(0.01)
		if meleeActive then
			local weapon = getMeleeWeapon()
			local sendActions = weapon and weapon:FindFirstChild("SendActions")
			
			if sendActions then
				local targets = getTargets()
				if #targets > 0 then
					local count = 0
					for _, target in ipairs(targets) do
						if not meleeActive or getMeleeWeapon() ~= weapon then break end
						if count >= 3 then break end
						if isAlive(target) and not hasShield(target) then
							count = count + 1
							local args = {
