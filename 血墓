local isTeleporting = false
local isScaling = false
local tpConnection
local scaleConnection

local originalCollisionGroup = {}
local originalTransparencies = {}
local originalSizes = {}

local targetDistance = 5
local headScaleSize = 6

local function getTargets()
    local targets = {}
    local enemies = Workspace:FindFirstChild("Enemies")
    if enemies then
        for _, enemy in ipairs(enemies:GetChildren()) do
            local head = enemy:FindFirstChild("Head")
            local hitbox = enemy:FindFirstChild("HeadHitbox")
            if head and hitbox then
                table.insert(targets, {head = head, hitbox = hitbox, model = enemy})
            end
        end
    end
    return targets
end

local function cleanTargetState(head, hitbox)
    if head and hitbox then
        if originalSizes[head] then head.Size = originalSizes[head] end
        if originalSizes[hitbox] then hitbox.Size = originalSizes[hitbox] end
        
        if head:IsA("SpecialMesh") or head:FindFirstChildOfClass("SpecialMesh") then
            local mesh = head:IsA("SpecialMesh") and head or head:FindFirstChildOfClass("SpecialMesh")
            mesh.MeshType = Enum.MeshType.Head
        end
        if hitbox:IsA("SpecialMesh") or hitbox:FindFirstChildOfClass("SpecialMesh") then
            local mesh = hitbox:IsA("SpecialMesh") and hitbox or hitbox:FindFirstChildOfClass("SpecialMesh")
            mesh.MeshType = Enum.MeshType.Head
        end
        
        head.Transparency = originalTransparencies[head] or 0
        hitbox.Transparency = originalTransparencies[hitbox] or 0
        head.Massless = false
        hitbox.Massless = false
        head.CanCollide = true
        hitbox.CanCollide = true
    end
end

local function restoreLocalPlayerCollision()
    local character = LocalPlayer.Character
    if character then
        for _, part in ipairs(character:GetChildren()) do
            if part:IsA("BasePart") and originalCollisionGroup[part.Name] ~= nil then
                part.CanCollide = originalCollisionGroup[part.Name]
            end
        end
    end
    table.clear(originalCollisionGroup)
end

local function updateScaleLogic()
    if not isScaling then return end
    
    local currentTargets = getTargets()
    for _, target in ipairs(currentTargets) do
        local currentHead = target.head
        local currentHeadHitbox = target.hitbox
        
        if not originalSizes[currentHead] then originalSizes[currentHead] = currentHead.Size end
        if not originalSizes[currentHeadHitbox] then originalSizes[currentHeadHitbox] = currentHeadHitbox.Size end
        if not originalTransparencies[currentHead] then originalTransparencies[currentHead] = currentHead.Transparency end
        if not originalTransparencies[currentHeadHitbox] then originalTransparencies[currentHeadHitbox] = currentHeadHitbox.Transparency end
        
        local desiredSize = Vector3.new(headScaleSize, headScaleSize, headScaleSize)
        if currentHead.Size ~= desiredSize then
            currentHead.Size = desiredSize
            currentHeadHitbox.Size = desiredSize
            
            local mesh1 = currentHead:IsA("SpecialMesh") and currentHead or currentHead:FindFirstChildOfClass("SpecialMesh")
            if not mesh1 then mesh1 = Instance.new("SpecialMesh", currentHead) end
            mesh1.MeshType = Enum.MeshType.Brick
            
            local mesh2 = currentHeadHitbox:IsA("SpecialMesh") and currentHeadHitbox or currentHeadHitbox:FindFirstChildOfClass("SpecialMesh")
            if not mesh2 then mesh2 = Instance.new("SpecialMesh", currentHeadHitbox) end
            mesh2.MeshType = Enum.MeshType.Brick

            currentHead.Transparency = 0.6
            currentHeadHitbox.Transparency = 0.6
            currentHead.Massless = true
            currentHeadHitbox.Massless = true
        end
    end
end

local function startScaleLoop()
    if scaleConnection then scaleConnection:Disconnect() end
    scaleConnection = RunService.RenderStepped:Connect(function()
        if not isScaling then
            scaleConnection:Disconnect()
            scaleConnection = nil
            return
        end
        updateScaleLogic()
    end)
end

local function stopScaleLogic()
    if scaleConnection then scaleConnection:Disconnect() scaleConnection = nil end
    local currentTargets = getTargets()
    for _, target in ipairs(currentTargets) do
        cleanTargetState(target.head, target.hitbox)
        originalSizes[target.head] = nil
        originalSizes[target.hitbox] = nil
        originalTransparencies[target.head] = nil
        originalTransparencies[target.hitbox] = nil
    end
end

local function startTeleportLoop()
    if tpConnection then tpConnection:Disconnect() end
    
    table.clear(originalCollisionGroup)
    local character = LocalPlayer.Character
    if character then
        for _, part in ipairs(character:GetChildren()) do
            if part:IsA("BasePart") then
                originalCollisionGroup[part.Name] = part.CanCollide
            end
        end
    end

    tpConnection = RunService.RenderStepped:Connect(function()
        if not isTeleporting then
            tpConnection:Disconnect()
            tpConnection = nil
            return
        end

        local currentTargets = getTargets()
        local char = LocalPlayer.Character
        local rootPart = char and char:FindFirstChild("HumanoidRootPart")
        
        if char then
            for _, part in ipairs(char:GetChildren()) do
                if part:IsA("BasePart") then
                    if part.CanCollide ~= false then
                        part.CanCollide = false
                    end
                end
            end
        end

        if rootPart and #currentTargets > 0 then
            local targetCFrame = rootPart.CFrame * CFrame.new(0, 0, -targetDistance)
            
            for _, target in ipairs(currentTargets) do
                local currentHead = target.head
                local currentHeadHitbox = target.hitbox
                local bg = target.model
                
                local currentVelocity = currentHead.AssemblyLinearVelocity
                if currentVelocity.Magnitude > 0 then
                    currentHead.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    currentHead.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                end
                
                if currentHead.Parent == bg then
                    currentHead.CFrame = targetCFrame
                end
                if currentHeadHitbox.Parent == bg then
                    currentHeadHitbox.CFrame = targetCFrame
                end
            end
        end
    end)
end

local function stopTeleportLogic()
    if tpConnection then tpConnection:Disconnect() tpConnection = nil end
    restoreLocalPlayerCollision()
end

