								SwingRemote:FireServer(unpack({KatanaWeapon}))
							end
							if PlankWeapon then
								SwingRemote:FireServer(unpack({PlankWeapon}))
							end
							
							local damageArgs = {
								humanoid,
								"Katana",
								enemyPart.Position
							}
							DamageRemote:FireServer(unpack(damageArgs))
						end
					end
				end
			end
		end
	end
end)

