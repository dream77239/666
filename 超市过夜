task.spawn(function()
	while task.wait(0.1) do
		if KillEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
			local myPart = LocalPlayer.Character.HumanoidRootPart
			for _, enemy in ipairs(TargetFolder:GetChildren()) do
				local humanoid = enemy:FindFirstChildWhichIsA("Humanoid")
				if humanoid and humanoid.Health > 0 then
					local enemyPart = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChildWhichIsA("BasePart")
