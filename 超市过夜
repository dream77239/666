local function ClearEspTable(storage)
	for obj, assets in pairs(storage) do
		if assets.Highlight then assets.Highlight:Destroy() end
		if assets.Billboard then assets.Billboard:Destroy() end
	end
	table.clear(storage)
end

local function GetItemType(object)
	local toolStats = object:FindFirstChild("ToolStats")
	if toolStats then
		local itemTypeObj = toolStats:FindFirstChild("ItemType")
		if itemTypeObj and itemTypeObj:IsA("ValueBase") then
			return itemTypeObj.Value
		end
	end
	return nil
end

local function GetItemDisplayName(object)
	local t = GetItemType(object)
	if t and TypeMap[t] then
		return TypeMap[t]
	end
	return object.Name
end

local function CreateEsp(object, color, storage, isEnemy)
	if not object:IsA("Model") and not object:IsA("BasePart") then return end
	
	local displayName = isEnemy and "怪物" or GetItemDisplayName(object)
	
	local highlight = Instance.new("Highlight")
	highlight.FillTransparency = 1
	highlight.OutlineColor = color
	highlight.OutlineTransparency = 0
	highlight.Adornee = object
	highlight.Parent = ScreenGui
	
	local billboard = Instance.new("BillboardGui")
	billboard.Size = UDim2.new(0, 100, 0, 30)
	billboard.AlwaysOnTop = true
	billboard.StudsOffset = Vector3.new(0, 2, 0)
	billboard.Adornee = object:IsA("Model") and (object.PrimaryPart or object:FindFirstChildWhichIsA("BasePart")) or object
	billboard.Parent = ScreenGui
	
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text = displayName
	label.TextColor3 = color
	label.TextSize = 14
	label.Font = Enum.Font.SourceSansBold
	label.Parent = billboard
	
	storage[object] = {Highlight = highlight, Billboard = billboard, CurrentName = displayName}
end

local function ManageEsp(enabled, folder, color, storage, isEnemy)
	if not enabled then 
		ClearEspTable(storage)
		return 
	end
	
	for _, child in ipairs(folder:GetChildren()) do
		local expectedName = isEnemy and "怪物" or GetItemDisplayName(child)
		local data = storage[child]
		
		if not data then
			CreateEsp(child, color, storage, isEnemy)
		else
			if not data.Highlight or data.Highlight.Parent ~= ScreenGui or data.Highlight.Adornee ~= child then
				if data.Highlight then data.Highlight:Destroy() end
				local highlight = Instance.new("Highlight")
				highlight.FillTransparency = 1
				highlight.OutlineColor = color
				highlight.OutlineTransparency = 0
				highlight.Adornee = child
				highlight.Parent = ScreenGui
				data.Highlight = highlight
			end
			if not data.Billboard or data.Billboard.Parent ~= ScreenGui or data.Billboard.Adornee ~= (child:IsA("Model") and (child.PrimaryPart or child:FindFirstChildWhichIsA("BasePart")) or child) or data.CurrentName ~= expectedName then
				if data.Billboard then data.Billboard:Destroy() end
				local billboard = Instance.new("BillboardGui")
				billboard.Size = UDim2.new(0, 100, 0, 30)
				billboard.AlwaysOnTop = true
				billboard.StudsOffset = Vector3.new(0, 2, 0)
				billboard.Adornee = child:IsA("Model") and (child.PrimaryPart or child:FindFirstChildWhichIsA("BasePart")) or child
				billboard.Parent = ScreenGui
				
				local label = Instance.new("TextLabel")
				label.Size = UDim2.new(1, 0, 1, 0)
				label.BackgroundTransparency = 1
				label.Text = expectedName
				label.TextColor3 = color
				label.TextSize = 14
				label.Font = Enum.Font.SourceSansBold
				label.Parent = billboard
				data.Billboard = billboard
				data.CurrentName = expectedName
			end
		end
	end
	
	for obj, assets in pairs(storage) do
		if not obj or not obj.Parent then
			if assets.Highlight then assets.Highlight:Destroy() end
			if assets.Billboard then assets.Billboard:Destroy() end
			storage[obj] = nil
		end
	end
end

